{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": [
    "src/**/*",
    "test/**/*.ts",
    "vite.config.ts",
    "playwright.config.ts",
    "playwright.was.config.ts",
    "playwright.wallet.config.ts",
    "scripts/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
